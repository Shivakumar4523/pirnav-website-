PORT=5000
ADMIN_JWT_SECRET=change-me-to-a-long-random-value

# Seed initial admin user if none exists
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# When set, limits CORS origins. Example: http://localhost:5173
# If empty, CORS is deny-by-default (only same-origin requests will work).
CORS_ORIGINS=

