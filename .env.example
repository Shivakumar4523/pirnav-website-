#
# Copy to `.env` (DO NOT commit the real `.env`).
#

# Frontend (Vite) - optional because the app uses relative `/api/*` routes.
VITE_API_BASE_URL=http://localhost:5000
# Used only in `vite dev` to proxy /api to the backend.
VITE_API_PROXY_TARGET=http://localhost:5000

# Backend (Express) - required for admin auth.
PORT=5000
ADMIN_JWT_SECRET=change-me-to-a-long-random-value
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Limit CORS when you have cross-origin traffic.
# In production with same-origin nginx routing, you can leave this blank.
# For local dev across origins, set this to your frontend origin (e.g. http://localhost:5173).
CORS_ORIGINS=
# Optional exact overrides when your backend uses custom controller routes.
# VITE_JOB_APPLICATIONS_API_BASE=https://localhost:5000/api/JobApplications
# VITE_CANDIDATES_API_BASE=https://localhost:5000/api/candidates
# VITE_INTERVIEW_API_BASE=https://localhost:5000/api/interview
# VITE_INTERVIEWS_API_BASE=https://localhost:5000/api/interviews
# VITE_DEFAULT_INTERVIEW_MANAGER_ID=1
